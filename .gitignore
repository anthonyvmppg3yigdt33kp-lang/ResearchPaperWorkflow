# Research Paper Workflow Framework

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# R
.Rproj.user/
.Rhistory
.RData

# Generated paper projects
papers/
strategy/
data/

# External code intake keeps review manifests, but mirrored third-party source
# copies must stay local until license/provenance review approves redistribution.
code_library/external_sources/*/original/
code_library/external_sources/*/_clone_tmp/

# Data (large files)
*.h5ad
*.rds
*.Rds
*.bam
*.sam
*.fastq
*.fq
*.tar.gz

# Results (binary) — only in results/ directories
results/*.pdf
results/*.png
results/*.csv
results/*.tsv
results/

# Environment
.venv/
venv/
*.conda/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Secrets
.env
credentials.*

# Logs
*.log
